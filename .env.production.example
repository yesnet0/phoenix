# Phoenix Production Environment Variables
# Copy to .env and fill in values before deploying

# Neo4j — used by API and worker containers
NEO4J_PASSWORD=change_me_to_a_strong_password

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=https://phoenix.disclose.io

# Logging
LOG_LEVEL=INFO

# Domain — used by deploy.sh for certbot
DOMAIN=phoenix.disclose.io
EMAIL=casey@disclose.io
